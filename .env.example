# =============================================================================
# Variáveis de ambiente da pipeline de dados (Python) — Piso da Enfermagem
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env` (não versionado) e ajuste os caminhos:
#     cp .env.example .env
# No servidor EC2 os valores abaixo já servem; confirme apenas as origens da
# bronze (que vivem em outros diretórios) e o caminho da planilha do deflator.
# =============================================================================

# Raiz do projeto de dados no servidor compartilhado.
PISO_DATA_ROOT=/mnt/data/estudos/piso_enfermagem

# Camadas prata e ouro. Se comentadas, são derivadas de PISO_DATA_ROOT
# (PISO_DATA_ROOT/prata e PISO_DATA_ROOT/ouro).
# PISO_PRATA=/mnt/data/estudos/piso_enfermagem/prata
# PISO_OURO=/mnt/data/estudos/piso_enfermagem/ouro

# Origens da camada bronze — dados brutos (RAIS, Novo CAGED) em outros diretórios.
PISO_BRONZE_CAGED=/mnt/data/bronze/novo_caged
PISO_BRONZE_RAIS=/mnt/data/bronze/rais

# Deflator INPC.
#   PISO_DEFLATOR_XLSX: planilha bruta de origem (usada por `piso deflator`).
#   PISO_DEFLATOR:      parquet gerado (default: PISO_PRATA/deflator.parquet).
PISO_DEFLATOR_XLSX=/mnt/data/estudos/piso_enfermagem/prata/deflator.xlsx
# PISO_DEFLATOR=/mnt/data/estudos/piso_enfermagem/prata/deflator.parquet

# Paralelismo do DuckDB (opcional).
PISO_DUCKDB_THREADS=4
